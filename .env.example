# Supabase — get these from your project dashboard under Settings → API.
# Copy this file to .env.local and fill in real values. Never commit .env.local.
VITE_SUPABASE_URL=your_supabase_project_url

# Use your project's publishable key (sb_publishable_…).
# The legacy VITE_SUPABASE_ANON_KEY is also still supported as a fallback.
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
